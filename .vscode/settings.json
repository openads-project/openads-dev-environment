{
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
    "editor.indentSize": "tabSize",
    "editor.tabSize": 2,
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.indentSize": "tabSize",
    "editor.tabSize": 4,
  },
  "C_Cpp.clang_format_style": "file:${workspaceFolder}/.vscode/format/.clang-format",
  "C_Cpp.codeAnalysis.clangTidy.args": [
    "--config-file",
    "${workspaceFolder}/.vscode/lint/.clang-tidy"
  ],
  "C_Cpp.codeAnalysis.clangTidy.enabled": true,
  "python.analysis.extraPaths": [
    "/opt/ros/${env:ROS_DISTRO}/lib/python3.12/site-packages"
  ],
  "python.autoComplete.extraPaths": [
    "/opt/ros/${env:ROS_DISTRO}/lib/python3.12/site-packages"
  ],
  "black-formatter.args": [
    "--line-length",
    "130"
  ],
  "flake8.args": [
    "--config=${workspaceFolder}/.vscode/lint/ament_flake8.ini"
  ],
  "flake8.enabled": true,
  "ROS2.distro": "jazzy",
}
